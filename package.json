{
  "name": "AISOS",
  "version": "1.6.8",
  "description": "AISOS",
  "main": "main.js",
  "author": "Acrox",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build-win": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^25.9.8",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "@emailjs/nodejs": "^5.0.2",
    "axios": "^1.13.2",
    "electron-updater": "^6.6.2",
    "firebase": "^12.15.0",
    "fs-extra": "^11.3.2",
    "gdown": "^1.0.6",
    "google-drive-downloader": "^0.2.0",
    "megajs": "^1.3.9"
  },
  "build": {
    "appId": "com.acrox.store",
    "productName": "AISOS",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/.bin"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "artifactName": "AISOS.Setup.${version}.exe"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "acroxjvxx",
        "repo": "ACROXStoreRelease"
      }
    ]
  }
}
